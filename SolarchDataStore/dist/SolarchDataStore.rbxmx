        <string name="Name">Config</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	Solarch DataStore — Configuration
	Edit this file only; all other modules read from here.
]]

export type ConfigTable = {
	ApiUrl: string,
	ApiKey: string,
	UniverseId: number?,
	DefaultScope: string,
	SessionRefreshBuffer: number,
	MaxRetries: number,
	RetryBaseDelay: number,
	RequestTimeout: number,
	UpdateAsyncMaxRetries: number,
	DeepCopyOnRead: boolean,
	CacheDataStoreInstances: boolean,
	Debug: boolean,
	RunSetupValidator: boolean,
	StudioUniverseId: number,
	GetUniverseId: (self: ConfigTable) -> number,
	IsConfigured: (self: ConfigTable) -> (boolean, string?),
	GetApiUrl: (self: ConfigTable) -> string,
}

local Config: ConfigTable = {
	ApiUrl = "http://localhost:3000",
	ApiKey = "YOUR_API_KEY_HERE",
	UniverseId = nil,
	DefaultScope = "global",
	SessionRefreshBuffer = 30,
	MaxRetries = 3,
	RetryBaseDelay = 0.5,
	RequestTimeout = 30,
	-- Retries on version conflict during UpdateAsync (optimistic concurrency)
	UpdateAsyncMaxRetries = 5,
	-- Return deep copies from GetAsync so callers cannot corrupt the session cache
	DeepCopyOnRead = true,
	-- Reuse DataStore instances per name+scope (Roblox DataStoreService behavior)
	CacheDataStoreInstances = true,
	Debug = true,
	RunSetupValidator = true,
	StudioUniverseId = 0,
} :: any

function Config.GetUniverseId(): number
	if Config.UniverseId and Config.UniverseId > 0 then
		return Config.UniverseId
	end
	if game.GameId > 0 then
		return game.GameId
	end
	if Config.StudioUniverseId > 0 then
		return Config.StudioUniverseId
	end
	return 0
end

function Config.IsConfigured(): (boolean, string?)
	if Config.ApiKey == "" or Config.ApiKey == "YOUR_API_KEY_HERE" then
		return false, "Config.ApiKey is not set"
	end
	if Config.ApiUrl == "" then
		return false, "Config.ApiUrl is not set"
	end
	if string.find(Config.ApiUrl, "YOUR") then
		return false, "Config.ApiUrl is invalid"
	end
	return true, nil
end

function Config.GetApiUrl(): string
	local url = Config.ApiUrl
	if string.sub(url, -1) == "/" then
		return string.sub(url, 1, -2)
	end
	return url
end

return Config
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX3">
      <Properties>
        <string name="Name">Errors</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	Roblox DataStoreService uyumlu hata tipleri.
	https://create.roblox.com/docs/reference/engine/enums/DataStoreRequestType
]]

export type DataStoreErrorType =
	"InternalError"
	| "NetworkError"
	| "AuthError"
	| "RateLimitError"
	| "ConfigError"
	| "InvalidKey"
	| "NotFound"

export type DataStoreError = {
	ErrorType: DataStoreErrorType,
	Message: string,
	StatusCode: number?,
}

local Errors = {}

function Errors.new(errorType: DataStoreErrorType, message: string, statusCode: number?): DataStoreError
	return {
		ErrorType = errorType,
		Message = message,
		StatusCode = statusCode,
	}
end

function Errors.fromHttpStatus(statusCode: number, body: string?): DataStoreError
	local message = body or `HTTP {statusCode}`
	if statusCode == 401 or statusCode == 403 then
		return Errors.new("AuthError", message, statusCode)
	end
	if statusCode == 429 then
		return Errors.new("RateLimitError", message, statusCode)
	end
	if statusCode >= 500 then
		return Errors.new("InternalError", message, statusCode)
	end
	return Errors.new("NetworkError", message, statusCode)
end

function Errors.toString(err: DataStoreError): string
	return `[SolarchDataStore:{err.ErrorType}] {err.Message}`
end

return Errors
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX4">
      <Properties>
        <string name="Name">Util</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	Shared utilities — deep copy, table merge, key validation helpers.
]]

local Util = {}

export type JSONValue = string | number | boolean | { [string]: JSONValue } | { JSONValue }

function Util.deepCopy<T>(value: T): T
	local t = typeof(value)
	if t ~= "table" then
		return value
	end
	local copy = {} :: any
	for k, v in pairs(value :: any) do
		copy[Util.deepCopy(k)] = Util.deepCopy(v)
	end
	return copy :: T
end

function Util.reconcile(data: { [string]: any }, template: { [string]: any }): { [string]: any }
	local result = Util.deepCopy(data)
	for key, defaultValue in pairs(template) do
		local current = result[key]
		if current == nil then
			result[key] = Util.deepCopy(defaultValue)
		elseif typeof(current) == "table" and typeof(defaultValue) == "table" then
			result[key] = Util.reconcile(current, defaultValue)
		end
	end
	return result
end

function Util.isValidKey(key: string): (boolean, string?)
	if typeof(key) ~= "string" or key == "" then
		return false, "Key must be a non-empty string"
	end
	if #key > 256 then
		return false, "Key must be 256 characters or fewer"
	end
	if string.find(key, "\0") then
		return false, "Key cannot contain null bytes"
	end
	return true, nil
end

function Util.trimUrl(url: string): string
	if string.sub(url, -1) == "/" then
		return string.sub(url, 1, -2)
	end
	return url
end

return Util
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX5">
      <Properties>
        <string name="Name">KeyQueue</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	Per-key async queue — serializes mutations on the same key to prevent
	race conditions (mirrors Roblox DataStore ordering guarantees per key).
]]

export type KeyQueue = {
	Enqueue: <T>(self: KeyQueue, key: string, operation: () -> T) -> T,
	Clear: (self: KeyQueue, key: string?) -> (),
}

local KeyQueue = {}
KeyQueue.__index = KeyQueue

type QueueEntry = {
	running: boolean,
	pending: { () -> () },
}

function KeyQueue.new(): KeyQueue
	local self = setmetatable({}, KeyQueue)
	self._queues = {} :: { [string]: QueueEntry }
	return self
end

function KeyQueue:_getOrCreate(key: string): QueueEntry
	local entry = self._queues[key]
	if entry then
		return entry
	end
	entry = { running = false, pending = {} }
	self._queues[key] = entry
	return entry
end

function KeyQueue:_drain(key: string, entry: QueueEntry)
	if entry.running then
		return
	end
	local nextFn = table.remove(entry.pending, 1)
	if not nextFn then
		self._queues[key] = nil
		return
	end
	entry.running = true
	task.spawn(function()
		local ok, err = pcall(nextFn)
		entry.running = false
		if not ok then
			warn(`[KeyQueue] Operation failed for "{key}": {err}`)
		end
		self:_drain(key, entry)
	end)
end

function KeyQueue:Enqueue<T>(key: string, operation: () -> T): T
	local finished = false
	local result: any = nil
	local thrown: any = nil

	local entry = self:_getOrCreate(key)
	table.insert(entry.pending, function()
		local ok, value = pcall(operation)
		if ok then
			result = value
		else
			thrown = value
		end
		finished = true
	end)
	self:_drain(key, entry)

	while not finished do
		task.wait()
	end

	if thrown ~= nil then
		error(thrown, 2)
	end

	return result
end

function KeyQueue:Clear(key: string?)
	if key then
		self._queues[key] = nil
	else
		table.clear(self._queues)
	end
end

return KeyQueue
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX6">
      <Properties>
        <string name="Name">HttpClient</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
local HttpService = game:GetService("HttpService")
local Errors = require(script.Parent:WaitForChild("Errors"))

export type HttpClient = {
	Request: (self: HttpClient, method: string, path: string, body: any?) -> (any?, Errors.DataStoreError?),
	RefreshSession: (self: HttpClient) -> (),
	GetSessionToken: (self: HttpClient) -> (string?, Errors.DataStoreError?),
}

local HttpClient = {}
HttpClient.__index = HttpClient

export type HttpClientOptions = {
	apiUrl: string,
	apiKey: string,
	universeId: number,
	sessionRefreshBuffer: number,
	maxRetries: number,
	retryBaseDelay: number,
	debug: boolean,
}

local function log(debug: boolean, message: string)
	if debug then
		print(`[SolarchDataStore] {message}`)
	end
end

function HttpClient.new(options: HttpClientOptions): HttpClient
	local self = setmetatable({}, HttpClient)
	self._options = options
	self._apiUrl = options.apiUrl
	self._sessionToken = nil :: string?
	self._sessionExpiresAt = 0
	self._refreshing = false
	return self
end

function HttpClient:RefreshSession()
	self._sessionToken = nil
	self._sessionExpiresAt = 0
end

function HttpClient:GetSessionToken(): (string?, Errors.DataStoreError?)
	if self._sessionToken and os.clock() < self._sessionExpiresAt then
		return self._sessionToken, nil
	end

	if self._options.universeId <= 0 then
		return nil, Errors.new(
			"ConfigError",
			"Invalid UniverseId — set Config.UniverseId or Config.StudioUniverseId (GameId is 0 in Studio)."
		)
	end

	while self._refreshing do
		task.wait()
	end

	if self._sessionToken and os.clock() < self._sessionExpiresAt then
		return self._sessionToken, nil
	end

	self._refreshing = true

	local ok, response = pcall(function()
		return HttpService:RequestAsync({
			Url = `{self._apiUrl}/api/v2/session`,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json",
				["x-api-key"] = self._options.apiKey,
			},
			Body = HttpService:JSONEncode({
				universeId = self._options.universeId,
				scopes = { "datastore:read", "datastore:write" },
			}),
		})
	end)

	self._refreshing = false

	if not ok then
		return nil, Errors.new("NetworkError", tostring(response))
	end

	if not response.Success then
		return nil, Errors.fromHttpStatus(response.StatusCode, response.Body)
	end

	local decodeOk, body = pcall(function()
		return HttpService:JSONDecode(response.Body)
	end)
	if not decodeOk or typeof(body) ~= "table" or body.accessToken == nil then
		return nil, Errors.new("InternalError", "Invalid session response")
	end

	self._sessionToken = body.accessToken
	self._sessionExpiresAt = os.clock() + (body.expiresIn or 300) - self._options.sessionRefreshBuffer
	log(self._options.debug, "Session token acquired")
	return self._sessionToken, nil
end

function HttpClient:_backoff(attempt: number, statusCode: number?): number
	local base = self._options.retryBaseDelay * attempt
	if statusCode == 429 then
		return base * 3
	end
	if statusCode and statusCode >= 500 then
		return base * 2
	end
	return base
end

function HttpClient:Request(method: string, path: string, body: any?): (any?, Errors.DataStoreError?)
	local lastError: Errors.DataStoreError? = nil

	for attempt = 1, self._options.maxRetries do
		local token, sessionErr = self:GetSessionToken()
		if not token then
			lastError = sessionErr
			task.wait(self._options.retryBaseDelay * attempt)
			continue
		end

		local req: { Url: string, Method: string, Headers: { [string]: string }, Body: string? } = {
			Url = `{self._apiUrl}{path}`,
			Method = method,
			Headers = {
				["Content-Type"] = "application/json",
				["Authorization"] = `Bearer {token}`,
			},
		}

		if body ~= nil then
			req.Body = HttpService:JSONEncode(body)
		end

		local ok, response = pcall(function()
			return HttpService:RequestAsync(req)
		end)

		if not ok then
			lastError = Errors.new("NetworkError", tostring(response))
			task.wait(self._options.retryBaseDelay * attempt)
			continue
		end

		if not response.Success then
			if response.StatusCode == 401 then
				self:RefreshSession()
				task.wait(self._options.retryBaseDelay * attempt)
				continue
			end

			if response.StatusCode == 429 or response.StatusCode >= 500 then
				lastError = Errors.fromHttpStatus(response.StatusCode, response.Body)
				task.wait(self:_backoff(attempt, response.StatusCode))
				continue
			end

			return nil, Errors.fromHttpStatus(response.StatusCode, response.Body)
		end

		if response.Body == "" or response.StatusCode == 204 then
			return nil, nil
		end

		local decodeOk, decoded = pcall(function()
			return HttpService:JSONDecode(response.Body)
		end)
		if not decodeOk then
			return nil, Errors.new("InternalError", "JSON decode failed")
		end

		return decoded, nil
	end

	return nil, lastError or Errors.new("NetworkError", "Request failed after all retries")
end

return HttpClient
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX7">
      <Properties>
        <string name="Name">DataStore</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
local HttpService = game:GetService("HttpService")
local Errors = require(script.Parent:WaitForChild("Errors"))
local KeyQueue = require(script.Parent:WaitForChild("KeyQueue"))
local Util = require(script.Parent:WaitForChild("Util"))

export type GetOptions = {
	UseCache: boolean?,
}

export type DataStore = {
	GetAsync: (self: DataStore, key: string, options: GetOptions?) -> any?,
	SetAsync: (self: DataStore, key: string, value: any, userIds: { number }?) -> (),
	UpdateAsync: (self: DataStore, key: string, transform: (any?) -> any?, userIds: { number }?) -> any?,
	RemoveAsync: (self: DataStore, key: string) -> (),
	IncrementAsync: (self: DataStore, key: string, delta: number?, userIds: { number }?) -> number,
	GetVersionAsync: (self: DataStore, key: string) -> string?,
	InvalidateCache: (self: DataStore, key: string?) -> (),
}

export type DataStoreOptions = {
	httpClient: any,
	scope: string,
	namePrefix: string,
	debug: boolean,
	deepCopyOnRead: boolean,
	updateAsyncMaxRetries: number,
}

local DataStore = {}
DataStore.__index = DataStore

local function encodeSegment(value: string): string
	return HttpService:UrlEncode(value)
end

local function fullKey(prefix: string, key: string): string
	if prefix == "" then
		return key
	end
	return `{prefix}/{key}`
end

local function assertKey(key: string)
	local valid, reason = Util.isValidKey(key)
	if not valid then
		error(Errors.toString(Errors.new("InvalidKey", reason or "Invalid key")), 2)
	end
end

local function raiseIfError(err: Errors.DataStoreError?)
	if err then
		error(Errors.toString(err), 2)
	end
end

local function isVersionConflict(err: Errors.DataStoreError?): boolean
	if not err then
		return false
	end
	return err.StatusCode == 400 and string.find(err.Message, "DS_TAMPER") ~= nil
		or string.find(err.Message, "TAMPER") ~= nil
		or string.find(err.Message, "version") ~= nil
end

function DataStore.new(options: DataStoreOptions): DataStore
	local self = setmetatable({}, DataStore)
	self._client = options.httpClient
	self._scope = options.scope
	self._prefix = options.namePrefix
	self._debug = options.debug
	self._deepCopyOnRead = options.deepCopyOnRead
	self._updateMaxRetries = options.updateAsyncMaxRetries
	self._cache = {} :: { [string]: any }
	self._cacheLoaded = {} :: { [string]: boolean }
	self._versions = {} :: { [string]: number? }
	self._queue = KeyQueue.new()
	return self
end

function DataStore:_path(key: string): string
	return `/api/v2/datastore/{encodeSegment(self._scope)}/{encodeSegment(fullKey(self._prefix, key))}`
end

function DataStore:_log(message: string)
	if self._debug then
		print(`[SolarchDataStore/{self._prefix}] {message}`)
	end
end

function DataStore:_maybeCopy<T>(value: T): T
	if self._deepCopyOnRead and typeof(value) == "table" then
		return Util.deepCopy(value)
	end
	return value
end

function DataStore:_parseGetResult(result: any?): any?
	if result == nil then
		return nil
	end
	if result.payload ~= nil then
		return result.payload
	end
	if result.value == nil then
		return nil
	end
	return result.value
end

function DataStore:_applyGetResult(key: string, result: any?): any?
	local value = self:_parseGetResult(result)
	if result and result.version then
		self._versions[key] = result.version
	end
	self._cache[key] = value
	self._cacheLoaded[key] = true
	return self:_maybeCopy(value)
end

function DataStore:InvalidateCache(key: string?)
	if key then
		self._cache[key] = nil
		self._cacheLoaded[key] = false
		self._versions[key] = nil
	else
		table.clear(self._cache)
		table.clear(self._cacheLoaded)
		table.clear(self._versions)
	end
end

function DataStore:_fetchRemote(key: string): any?
	local result, err = self._client:Request("GET", self:_path(key))
	raiseIfError(err)
	return self:_applyGetResult(key, result)
end

function DataStore:GetAsync(key: string, options: GetOptions?): any?
	assertKey(key)

	if options and options.UseCache == false then
		self:InvalidateCache(key)
	elseif self._cacheLoaded[key] then
		return self:_maybeCopy(self._cache[key])
	end

	return self:_fetchRemote(key)
end

function DataStore:_write(
	key: string,
	method: string,
	payload: any?,
	pathSuffix: string?
): (any?, Errors.DataStoreError?)
	local path = if pathSuffix then `{self:_path(key)}{pathSuffix}` else self:_path(key)
	local body = if payload ~= nil then payload else nil
	return self._client:Request(method, path, body)
end

function DataStore:SetAsync(key: string, value: any, _userIds: { number }?): ()
	assertKey(key)
	self._queue:Enqueue(key, function()
		local body: { key: string, scope: string, payload: any, expectedVersion: number? } = {
			key = fullKey(self._prefix, key),
			scope = self._scope,
			payload = value,
		}
		local version = self._versions[key]
		if version then
			body.expectedVersion = version
		end

		local result, err = self:_write(key, "POST", body)
		raiseIfError(err)

		if result and result.newVersion then
			self._versions[key] = result.newVersion
		end
		self._cache[key] = value
		self._cacheLoaded[key] = true
		self:_log(`SetAsync "{key}"`)
	end)
end

function DataStore:UpdateAsync(key: string, transform: (any?) -> any?, _userIds: { number }?): any?
	assertKey(key)

	return self._queue:Enqueue(key, function()
		for attempt = 1, self._updateMaxRetries do
			self:InvalidateCache(key)
			local current = self:_fetchRemote(key)
			local updated = transform(current)

			if updated == nil then
				return self:_maybeCopy(current)
			end

			local body: { key: string, scope: string, payload: any, expectedVersion: number? } = {
				key = fullKey(self._prefix, key),
				scope = self._scope,
				payload = updated,
			}
			local version = self._versions[key]
			if version then
				body.expectedVersion = version
			end

			local result, err = self:_write(key, "PUT", body)
			if err and isVersionConflict(err) and attempt < self._updateMaxRetries then
				self:_log(`UpdateAsync "{key}" version conflict — retry {attempt}/{self._updateMaxRetries}`)
				task.wait(0.1 * attempt)
				continue
			end
			raiseIfError(err)

			if result and result.newVersion then
				self._versions[key] = result.newVersion
			end
			self._cache[key] = updated
			self._cacheLoaded[key] = true
			self:_log(`UpdateAsync "{key}"`)
			return self:_maybeCopy(updated)
		end

		error(Errors.toString(Errors.new("InternalError", "UpdateAsync failed after version retries")), 2)
	end)
end

function DataStore:RemoveAsync(key: string): ()
	assertKey(key)
	self._queue:Enqueue(key, function()
		local _, err = self:_write(key, "DELETE")
		raiseIfError(err)
		self:InvalidateCache(key)
		self:_log(`RemoveAsync "{key}"`)
	end)
end

function DataStore:IncrementAsync(key: string, delta: number?, _userIds: { number }?): number
	assertKey(key)

	return self._queue:Enqueue(key, function()
		self:InvalidateCache(key)
		local _, err = self:_write(key, "POST", { delta = delta or 1 }, "/increment")
		raiseIfError(err)

		local value = self:_fetchRemote(key)
		if typeof(value) == "number" then
			return value
		end
		return 0
	end)
end

function DataStore:GetVersionAsync(key: string): string?
	assertKey(key)

	if self._versions[key] then
		return tostring(self._versions[key])
	end

	local result, err = self._client:Request("GET", self:_path(key))
	if err or result == nil then
		return nil
	end
	if result.version then
		self._versions[key] = result.version
		return tostring(result.version)
	end
	return nil
end

return DataStore
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX8">
      <Properties>
        <string name="Name">DataSchema</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	Default player profile schema — extend for your game.
	Used by PlayerDataManager for reconciliation on load.
]]

export type PlayerStats = {
	Kills: number,
	Deaths: number,
}

export type PlayerData = {
	Coins: number,
	Level: number,
	Experience: number,
	Inventory: { [string]: number },
	Stats: PlayerStats,
	LastLogin: number,
}

local DataSchema = {}

DataSchema.DefaultProfile = {
	Coins = 0,
	Level = 1,
	Experience = 0,
	Inventory = {},
	Stats = {
		Kills = 0,
		Deaths = 0,
	},
	LastLogin = 0,
} :: PlayerData

DataSchema.DataStoreName = "PlayerData"

return DataSchema
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX9">
      <Properties>
        <string name="Name">PlayerDataManager</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	PlayerDataManager — production-style session cache over SolarchDataStore.

	- Load on join, save on leave (UpdateAsync only)
	- Schema reconciliation after load
	- Deep-copied reads (callers cannot corrupt session cache)
	- BindToClose + periodic auto-save
	- Fail-closed: kick on load failure

	Usage:
		local PlayerDataManager = require(ServerScriptService.SolarchDataStore.PlayerDataManager)
		PlayerDataManager.Init()
		local coins = PlayerDataManager.Get(player, "Coins")
]]

local Players = game:GetService("Players")

local Config = require(script.Parent:WaitForChild("Config"))
local DataSchema = require(script.Parent:WaitForChild("DataSchema"))
local SolarchDataStore = require(script.Parent:WaitForChild("SolarchDataStore"))
local Util = require(script.Parent:WaitForChild("Util"))

export type PlayerData = DataSchema.PlayerData

local PlayerDataManager = {}

local SessionData: { [number]: PlayerData } = {}
local Loaded: { [number]: boolean } = {}
local store = SolarchDataStore:GetDataStore(DataSchema.DataStoreName)

local AUTO_SAVE_INTERVAL = 120
local BIND_TO_CLOSE_TIMEOUT = 30

local function profileKey(userId: number): string
	return "profile_" .. tostring(userId)
end

local function getPathValue(data: any, path: string): any
	local parts = string.split(path, ".")
	local current = data
	for _, part in ipairs(parts) do
		if typeof(current) ~= "table" then
			return nil
		end
		current = current[part]
	end
	return current
end

local function setPathValue(data: any, path: string, value: any): boolean
	local parts = string.split(path, ".")
	local current = data
	for i = 1, #parts - 1 do
		local part = parts[i]
		if typeof(current[part]) ~= "table" then
			current[part] = {}
		end
		current = current[part]
	end
	current[parts[#parts]] = value
	return true
end

function PlayerDataManager.IsLoaded(player: Player): boolean
	return Loaded[player.UserId] == true
end

function PlayerDataManager.Get(player: Player, path: string): any
	local data = SessionData[player.UserId]
	if not data then
		warn(`[PlayerDataManager] Get before load: {player.Name}`)
		return nil
	end
	return Util.deepCopy(getPathValue(data, path))
end

function PlayerDataManager.Set(player: Player, path: string, value: any): boolean
	local data = SessionData[player.UserId]
	if not data then
		return false
	end
	return setPathValue(data, path, value)
end

function PlayerDataManager.Increment(player: Player, path: string, delta: number): boolean
	local current = PlayerDataManager.Get(player, path)
	if typeof(current) ~= "number" then
		current = 0
	end
	return PlayerDataManager.Set(player, path, current + delta)
end

function PlayerDataManager.GetProfile(player: Player): PlayerData?
	local data = SessionData[player.UserId]
	if not data then
		return nil
	end
	return Util.deepCopy(data)
end

function PlayerDataManager.LoadProfile(player: Player): boolean
	local key = profileKey(player.UserId)
	local ok, result = pcall(function()
		return store:GetAsync(key, { UseCache = false })
	end)

	if not ok then
		warn(`[PlayerDataManager] Load failed for {player.Name}: {result}`)
		player:Kick("Could not load your data. Please rejoin.")
		return false
	end

	local profile: PlayerData
	if result == nil then
		profile = Util.deepCopy(DataSchema.DefaultProfile)
	else
		profile = Util.reconcile(result :: any, DataSchema.DefaultProfile) :: PlayerData
	end

	profile.LastLogin = os.time()
	SessionData[player.UserId] = profile
	Loaded[player.UserId] = true
	return true
end

function PlayerDataManager.SaveProfile(player: Player): boolean
	if not Loaded[player.UserId] then
		return false
	end

	local key = profileKey(player.UserId)
	local snapshot = Util.deepCopy(SessionData[player.UserId])

	local ok, err = pcall(function()
		store:UpdateAsync(key, function()
			return snapshot
		end)
	end)

	if not ok then
		warn(`[PlayerDataManager] Save failed for {player.Name}: {err}`)
		return false
	end
	return true
end

function PlayerDataManager.ReleasePlayer(player: Player)
	PlayerDataManager.SaveProfile(player)
	SessionData[player.UserId] = nil
	Loaded[player.UserId] = nil
end

function PlayerDataManager.SaveAll()
	for _, player in Players:GetPlayers() do
		PlayerDataManager.SaveProfile(player)
	end
end

function PlayerDataManager.Init()
	Players.PlayerAdded:Connect(function(player)
		PlayerDataManager.LoadProfile(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		PlayerDataManager.ReleasePlayer(player)
	end)

	for _, player in Players:GetPlayers() do
		task.spawn(PlayerDataManager.LoadProfile, player)
	end

	task.spawn(function()
		while true do
			task.wait(AUTO_SAVE_INTERVAL)
			PlayerDataManager.SaveAll()
		end
	end)

	game:BindToClose(function()
		for _, player in Players:GetPlayers() do
			task.spawn(function()
				PlayerDataManager.SaveProfile(player)
			end)
		end
		task.wait(BIND_TO_CLOSE_TIMEOUT)
	end)

	if Config.Debug then
		print("[PlayerDataManager] Initialized")
	end
end

return PlayerDataManager
]]></ProtectedString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="RBX10">
      <Properties>
        <string name="Name">SolarchDataStore</string>
        <token name="RunContext">0</token>
        <ProtectedString name="Source"><![CDATA[--!strict
--[[
	Solarch External DataStoreService
	Drop-in replacement for game:GetService("DataStoreService")
]]

local Config = require(script.Parent:WaitForChild("Config"))
local Errors = require(script.Parent:WaitForChild("Errors"))
local HttpClient = require(script.Parent:WaitForChild("HttpClient"))
local DataStoreModule = require(script.Parent:WaitForChild("DataStore"))

export type DataStore = DataStoreModule.DataStore
export type DataStoreError = Errors.DataStoreError

export type SolarchDataStoreService = {
	GetDataStore: (self: SolarchDataStoreService, name: string, scope: string?) -> DataStore,
	GetGlobalDataStore: (self: SolarchDataStoreService) -> DataStore,
	RefreshSession: (self: SolarchDataStoreService) -> (),
	GetHttpClient: (self: SolarchDataStoreService) -> any,
	GetUniverseId: (self: SolarchDataStoreService) -> number,
	IsConfigured: (self: SolarchDataStoreService) -> (boolean, string?),
	Errors: typeof(Errors),
}

local SolarchDataStoreService = {} :: SolarchDataStoreService
SolarchDataStoreService.__index = SolarchDataStoreService

local client = HttpClient.new({
	apiUrl = Config.GetApiUrl(),
	apiKey = Config.ApiKey,
	universeId = Config.GetUniverseId(),
	sessionRefreshBuffer = Config.SessionRefreshBuffer,
	maxRetries = Config.MaxRetries,
	retryBaseDelay = Config.RetryBaseDelay,
	debug = Config.Debug,
})

local instanceCache: { [string]: DataStore } = {}

local function cacheKey(name: string, scope: string): string
	return `{scope}::{name}`
end

function SolarchDataStoreService:GetDataStore(name: string, scope: string?): DataStore
	assert(typeof(name) == "string" and name ~= "", "DataStore name must be a non-empty string")
	local ok, errMsg = Config.IsConfigured()
	if not ok then
		error(Errors.toString(Errors.new("ConfigError", errMsg or "Configuration error")), 2)
	end

	local resolvedScope = scope or Config.DefaultScope
	if Config.CacheDataStoreInstances then
		local key = cacheKey(name, resolvedScope)
		local cached = instanceCache[key]
		if cached then
			return cached
		end
	end

	local ds = DataStoreModule.new({
		httpClient = client,
		scope = resolvedScope,
		namePrefix = name,
		debug = Config.Debug,
		deepCopyOnRead = Config.DeepCopyOnRead,
		updateAsyncMaxRetries = Config.UpdateAsyncMaxRetries,
	})

	if Config.CacheDataStoreInstances then
		instanceCache[cacheKey(name, resolvedScope)] = ds
	end

	return ds
end

function SolarchDataStoreService:GetGlobalDataStore(): DataStore
	return self:GetDataStore("Global", Config.DefaultScope)
end

function SolarchDataStoreService:RefreshSession()
	client:RefreshSession()
end

function SolarchDataStoreService:GetHttpClient()
	return client
end

function SolarchDataStoreService:GetUniverseId(): number
	return Config.GetUniverseId()
end

function SolarchDataStoreService:IsConfigured(): (boolean, string?)
	return Config.IsConfigured()
end

SolarchDataStoreService.Errors = Errors

return SolarchDataStoreService
]]></ProtectedString>
      </Properties>
